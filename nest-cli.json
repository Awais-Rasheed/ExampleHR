{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/time-off-monorepo/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/time-off-monorepo/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/time-off-monorepo",
  "projects": {
    "mock-hcm": {
      "type": "application",
      "root": "apps/mock-hcm",
      "entryFile": "main",
      "sourceRoot": "apps/mock-hcm/src",
      "compilerOptions": {
        "tsConfigPath": "apps/mock-hcm/tsconfig.app.json"
      }
    },
    "time-off-monorepo": {
      "type": "application",
      "root": "apps/time-off-monorepo",
      "entryFile": "main",
      "sourceRoot": "apps/time-off-monorepo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/time-off-monorepo/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}